# Copy to `.env` next to docker-compose.yml. Used by `docker compose`.

# ── Postgres (shared instance) ──────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong
# Per-app database users (isolated credentials on the shared Postgres instance).
TICKETING_DB_PASSWORD=change-me-ticketing
MOCKBANK_DB_PASSWORD=change-me-mockbank
# Host port only matters locally; leave 5432 in prod.
POSTGRES_HOST_PORT=5432

# ── Help Desk Hero (ticketing) ──────────────────────────────────────────────
# dev = local seam (no AWS); cognito = real Cognito.
TICKETING_AUTH_MODE=cognito
TICKETING_DEV_SECRET=unused-in-prod
TICKETING_FRONTEND_URL=https://helpdeskhero.georgegarciadev.com
TICKETING_API_URL=https://apis.georgegarciadev.com/api/v1
TICKETING_COGNITO_POOL_ID=
TICKETING_COGNITO_CLIENT_ID=
AWS_REGION=us-east-1
# Premade demo recruiter account (must be a confirmed Cognito user in the `agent` group).
TICKETING_DEMO_EMAIL=demo@georgegarciadev.com
TICKETING_DEMO_PASSWORD=

# ── Portfolio contact form (SES via API Gateway + Lambda) ───────────────────
# The HTTP API invoke URL of your contact Lambda, e.g.
# https://abc123.execute-api.us-east-2.amazonaws.com/contact
CONTACT_ENDPOINT=

# ── Demo accounts (bank + casino) ───────────────────────────────────────────
# One shared password for the pre-seeded recruiter demo logins. Baked into the
# bank/admin/casino web bundles (so the demo buttons can sign in) and used by the
# bank `seed:demo` script + the casino startup seed. The bank customer + casino
# player are `recruiter@demo.com`; the admin-console staff is `admin-recruiter@demo.com`.
DEMO_PASSWORD=change-me-demo

# ── Mock Bank ───────────────────────────────────────────────────────────────
MOCKBANK_JWT_SECRET=change-me-strong
MOCKBANK_FRONTEND_URL=https://bank.georgegarciadev.com
MOCKBANK_API_URL=https://bank-api.georgegarciadev.com/api
MOCKBANK_ADMIN_API_URL=https://bank-admin-api.georgegarciadev.com/api
MOCKBANK_ADMIN_FRONTEND_URL=https://bank-admin.georgegarciadev.com

# ── Lucky Spin Casino ───────────────────────────────────────────────────────
CASINO_API_URL=https://casino-api.georgegarciadev.com

# ── Datadog ─────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com

# ── Glow (video-first dating) ────────────────────────────────────────────────
# Runs as STAGING by default (cheap SMS/social bypass) — good for prod testing.
# REQUIRED: GLOW_DATABASE_URL (Neon pooled). For working video, set the LiveKit vars.
GLOW_APP_ENV=staging
GLOW_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/glow?sslmode=require
GLOW_SESSION_JWT_SECRET=change-me-32+-random-bytes
GLOW_PHONE_PEPPER=change-me-32+-random-bytes
# Bootstrap admin access (your E.164 number) → glow-admin.georgegarciadev.com
GLOW_ADMIN_PHONES=
# LiveKit (video). Blank = deploy boots but calls won't connect.
GLOW_LIVEKIT_URL=
GLOW_LIVEKIT_API_KEY=
GLOW_LIVEKIT_API_SECRET=
GLOW_LIVEKIT_WEBHOOK_KEY=
# Flip these to production values when ready (APP_ENV=production forbids the bypasses).
GLOW_SMS_MODE=dev
GLOW_SMS_ORIGINATION_NUMBER=
GLOW_SOCIAL_MODE=dev
GLOW_GOOGLE_CLIENT_ID=
GLOW_APPLE_CLIENT_ID=
GLOW_MODERATION_MODE=dev
GLOW_MEDIA_S3_BUCKET=
GLOW_MEDIA_CLOUDFRONT_DOMAIN=
GLOW_MEDIA_CLOUDFRONT_KEY_PAIR_ID=
GLOW_MEDIA_CLOUDFRONT_PRIVATE_KEY=
# Where the landing page's "Open Glow" buttons point.
GLOW_APP_URL=https://glowapp.georgegarciadev.com
