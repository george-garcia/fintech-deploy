# Copy to `.env` next to docker-compose.yml. Used by `docker compose`.

# ── Postgres (shared instance) ──────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong
# Per-app database users (isolated credentials on the shared Postgres instance).
TICKETING_DB_PASSWORD=change-me-ticketing
MOCKBANK_DB_PASSWORD=change-me-mockbank
# Host port only matters locally; leave 5432 in prod.
POSTGRES_HOST_PORT=5432

# ── Help Desk Hero (ticketing) ──────────────────────────────────────────────
# dev = local seam (no AWS); cognito = real Cognito.
TICKETING_AUTH_MODE=cognito
TICKETING_DEV_SECRET=unused-in-prod
TICKETING_FRONTEND_URL=https://helpdeskhero.georgegarciadev.com
TICKETING_API_URL=https://apis.georgegarciadev.com/api/v1
TICKETING_COGNITO_POOL_ID=
TICKETING_COGNITO_CLIENT_ID=
AWS_REGION=us-east-1
# Premade demo recruiter account (must be a confirmed Cognito user in the `agent` group).
TICKETING_DEMO_EMAIL=demo@georgegarciadev.com
TICKETING_DEMO_PASSWORD=

# ── Portfolio contact form (SES via API Gateway + Lambda) ───────────────────
# The HTTP API invoke URL of your contact Lambda, e.g.
# https://abc123.execute-api.us-east-2.amazonaws.com/contact
CONTACT_ENDPOINT=

# ── Mock Bank ───────────────────────────────────────────────────────────────
MOCKBANK_JWT_SECRET=change-me-strong
MOCKBANK_FRONTEND_URL=https://bank.georgegarciadev.com
MOCKBANK_API_URL=https://bank-api.georgegarciadev.com/api
MOCKBANK_ADMIN_API_URL=https://bank-admin-api.georgegarciadev.com/api
MOCKBANK_ADMIN_FRONTEND_URL=https://bank-admin.georgegarciadev.com

# ── Lucky Spin Casino ───────────────────────────────────────────────────────
CASINO_API_URL=https://casino-api.georgegarciadev.com

# ── Datadog ─────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com
